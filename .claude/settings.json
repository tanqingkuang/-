{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python -X utf8 .claude/hooks/check_py_file.py",
            "timeout": 30,
            "statusMessage": "py 语法 + ruff 单文件检查..."
          }
        ]
      }
    ]
  }
}
