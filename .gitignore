# macOS 应用程序包（构建产物，由打包流程生成，不纳入版本控制）
编队仿真.app/

# 打包 / 构建产物
build/
dist/
*.spec

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/

# 测试 / 缓存
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
config.ini
logs/

# 虚拟环境
.venv/
venv/

# 编辑器 / 系统
.DS_Store
.idea/

# draw.io 编辑临时备份
.$*.bkp

# Node 依赖（本项目 Node 仅用内置模块，勿在根目录 npm install）
node_modules/
package.json
package-lock.json
