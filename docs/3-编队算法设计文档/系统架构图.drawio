        </mxCell>
        <mxCell id="F2" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#FFFFFF;strokeColor=#2E7D32;" value="任务编排">
          <mxGeometry x="854" y="306" width="120" height="50" as="geometry" />
        </mxCell>
        <mxCell id="F3" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#FFFFFF;strokeColor=#2E7D32;" value="轨迹规划">
          <mxGeometry x="988" y="306" width="120" height="50" as="geometry" />
        </mxCell>
        <mxCell id="FLOWnote" parent="1" vertex="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontColor=#2E7D32;" value="按 Mode 选 / 切策略、组装入参，把计算派给算法组 →">
          <mxGeometry x="720" y="372" width="388" height="40" as="geometry" />
        </mxCell>

        <!-- ============ L3 黑板 ============ -->
        <mxCell id="L3" parent="1" vertex="1" style="swimlane;horizontal=0;startSize=42;fontSize=15;fontStyle=1;html=1;fillColor=#FFF3E0;strokeColor=#EF6C00;strokeWidth=2;verticalAlign=middle;align=center;" value="L3 黑板 Context">
          <mxGeometry x="40" y="490" width="1240" height="90" as="geometry" />
        </mxCell>
        <mxCell id="BB" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;fontStyle=1;fillColor=#FFE0B2;strokeColor=#EF6C00;strokeWidth=2;" value="Context — 定义一次任务过程中需要的全部内容">
          <mxGeometry x="110" y="510" width="1010" height="50" as="geometry" />
        </mxCell>

        <!-- ============ L4 叶类型 ============ -->
        <mxCell id="L4" parent="1" vertex="1" style="swimlane;horizontal=0;startSize=42;fontSize=15;fontStyle=1;html=1;fillColor=#F3E5F5;strokeColor=#6A1B9A;strokeWidth=2;verticalAlign=middle;align=center;" value="L4 叶类型">
          <mxGeometry x="40" y="610" width="1240" height="100" as="geometry" />
