        <mxCell id="LEAF" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fontStyle=1;fillColor=#E1BEE7;strokeColor=#6A1B9A;strokeWidth=2;" value="简单结构体与枚举，供上层使用&#10;PosInEarthS · VdInEarthS · MotionProfS · WayLineS · FormSnapshotS · AccInEarthS · FormStageE …">
          <mxGeometry x="110" y="632" width="1010" height="56" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
