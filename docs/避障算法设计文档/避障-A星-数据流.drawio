<mxfile host="Electron" agent="Codex">
  <diagram name="避障数据流" id="avoid-dataflow-current">
    <mxGraphModel dx="1800" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1900" pageHeight="900" background="#ffffff" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" parent="1" style="text;html=1;align=left;verticalAlign=top;fontSize=20;fontStyle=1;" value="二维平面避障（A*）当前数据流：性能快路径 + 全量安全回退 + 应用层确认闸" vertex="1">
          <mxGeometry height="32" width="1680" x="40" y="20" as="geometry" />
        </mxCell>

        <mxCell id="cfg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F9A825;strokeWidth=2;fontSize=13;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="① 外部文件边界&#10;&#10;• route_file：JSON / 钻石 XML&#10;• obstacles_file：JSON&#10;• 航点与障碍使用经纬度&#10;• 圆 / rect / polygon" vertex="1">
          <mxGeometry height="150" width="230" x="40" y="90" as="geometry" />
        </mxCell>
        <mxCell id="expand" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#EF6C00;strokeWidth=2;fontSize=13;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="② 配置与应用层展开&#10;&#10;• 统一 LLA→ENU&#10;• 航线首点作为 origin&#10;• GUI 只收稳定 DTO&#10;• 勾选本次启用障碍" vertex="1">
          <mxGeometry height="150" width="230" x="300" y="90" as="geometry" />
        </mxCell>
        <mxCell id="direct" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;fontSize=13;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="③ 逐腿直线快判&#10;&#10;• margin=0 候选集&#10;• 线段包围盒预筛&#10;• 全程无阻挡：保留端点&#10;• 完全跳过 A*" vertex="1">
          <mxGeometry height="150" width="230" x="560" y="90" as="geometry" />
        </mxCell>
        <mxCell id="astar" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;fontSize=13;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="④ 候选障碍 A*&#10;&#10;• 仅被阻挡航段进入&#10;• clearance + margin 候选&#10;• 候选障碍决定本腿 bounds&#10;• 输出格点折线" vertex="1">
          <mxGeometry height="150" width="230" x="820" y="90" as="geometry" />
        </mxCell>
        <mxCell id="simplify" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;fontSize=13;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="⑤ 去冗余 + cause&#10;&#10;• 视线段再次预筛&#10;• simplify_clearance_m&#10;• 记录逼出拐点的障碍&#10;• 为贴障弧准备来源" vertex="1">
          <mxGeometry height="150" width="230" x="1080" y="90" as="geometry" />
        </mxCell>
        <mxCell id="fullcheck" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#F9A825;strokeWidth=2;fontSize=13;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="⑥ 全量安全距离复核&#10;&#10;• 检查全部障碍&#10;• 使用 simplify_clearance_m&#10;• 发现候选漏筛时&#10;  进入安全慢路径" vertex="1">
          <mxGeometry height="150" width="240" x="1340" y="90" as="geometry" />
        </mxCell>

        <mxCell id="fallback" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;fontSize=13;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="安全慢路径&#10;&#10;漏筛 → 本腿使用全障碍 A* 重规划&#10;→ 再次去冗余与 cause 记录" vertex="1">
          <mxGeometry height="105" width="260" x="780" y="330" as="geometry" />
        </mxCell>
        <mxCell id="route" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;strokeWidth=2;fontSize=13;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="⑦ 航线几何构造&#10;&#10;• points_to_route 只摆点&#10;• allow_arc 时折叠贴障大弧&#10;• 高度按水平里程插值" vertex="1">
          <mxGeometry height="120" width="240" x="1080" y="320" as="geometry" />
        </mxCell>
        <mxCell id="feasible" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;fontSize=13;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="⑧ 后置可飞性&#10;&#10;• 全量真实障碍直线复核&#10;• 转角 / 腿长 / 固定 R 弧&#10;• 显式贴障弧采样" vertex="1">
          <mxGeometry height="120" width="240" x="1360" y="320" as="geometry" />
        </mxCell>
        <mxCell id="finish" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;fontSize=13;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="⑨ PlanResult 收口&#10;&#10;• 补剩余直线拐点 R&#10;• allow_arc 时烘焙剩余弧&#10;• 成功航线或 ERR_AVOID_*" vertex="1">
          <mxGeometry height="120" width="240" x="1360" y="500" as="geometry" />
        </mxCell>
        <mxCell id="app" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#EF6C00;strokeWidth=2;fontSize=13;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="⑩ gui_application&#10;&#10;PlanResult → 只读 PlannedRoute&#10;预览 / JSON或XML输出 / 采用" vertex="1">
          <mxGeometry height="110" width="250" x="1050" y="520" as="geometry" />
        </mxCell>
        <mxCell id="controller" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#546E7A;strokeWidth=2;fontSize=13;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="⑪ 人工确认后注入控制器&#10;&#10;采用：覆盖长机有效航线&#10;重置：恢复配置航线&#10;未确认预览不进入仿真" vertex="1">
          <mxGeometry height="120" width="260" x="740" y="520" as="geometry" />
        </mxCell>
        <mxCell id="down" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#546E7A;strokeWidth=2;dashed=1;fontSize=13;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="下游链路不改&#10;&#10;LeaderRoute 选段 → 位置跟踪 → 三自由度模型&#10;僚机继续编队跟随长机；GUI 显示当前航线与被封锁原航线" vertex="1">
          <mxGeometry height="120" width="620" x="40" y="520" as="geometry" />
        </mxCell>
        <mxCell id="failure" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;fontSize=13;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="不可飞 / 无路：返回具体原因码，不生成可采用航线，原配置航线保持可用" vertex="1">
          <mxGeometry height="65" width="560" x="1040" y="690" as="geometry" />
        </mxCell>

        <mxCell id="e1" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#37474F;strokeWidth=2;endArrow=block;" edge="1" source="cfg" target="expand"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#37474F;strokeWidth=2;endArrow=block;" edge="1" source="expand" target="direct"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" value="阻挡" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#1565C0;strokeWidth=2;endArrow=block;fontSize=12;" edge="1" source="direct" target="astar"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e4" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#37474F;strokeWidth=2;endArrow=block;" edge="1" source="astar" target="simplify"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e5" value="直线清空：绕过 A*" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#2E7D32;strokeWidth=2;endArrow=block;dashed=1;fontSize=12;" edge="1" source="direct" target="simplify"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="675" y="270" /><mxPoint x="1195" y="270" /></Array></mxGeometry></mxCell>
        <mxCell id="e6" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#37474F;strokeWidth=2;endArrow=block;" edge="1" source="simplify" target="fullcheck"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e7" value="发现漏筛" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#C62828;strokeWidth=2;endArrow=block;dashed=1;fontSize=12;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="fullcheck" target="fallback"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1460" y="280" /><mxPoint x="910" y="280" /></Array></mxGeometry></mxCell>
        <mxCell id="e8" value="重规划结果" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#C62828;strokeWidth=2;endArrow=block;dashed=1;fontSize=12;" edge="1" source="fallback" target="route"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e9" value="通过" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#2E7D32;strokeWidth=2;endArrow=block;fontSize=12;" edge="1" source="fullcheck" target="route"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e10" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#37474F;strokeWidth=2;endArrow=block;" edge="1" source="route" target="feasible"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e11" value="通过" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#2E7D32;strokeWidth=2;endArrow=block;fontSize=12;" edge="1" source="feasible" target="finish"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e12" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#37474F;strokeWidth=2;endArrow=block;" edge="1" source="finish" target="app"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e13" value="采用" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#EF6C00;strokeWidth=2;endArrow=block;fontSize=12;" edge="1" source="app" target="controller"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e14" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#37474F;strokeWidth=2;endArrow=block;" edge="1" source="controller" target="down"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e15" value="失败" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#C62828;strokeWidth=2;endArrow=block;dashed=1;fontSize=12;exitX=1;exitY=0.5;entryX=1;entryY=0.5;" edge="1" source="feasible" target="failure"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1640" y="380" /><mxPoint x="1660" y="380" /><mxPoint x="1660" y="722" /></Array></mxGeometry></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
