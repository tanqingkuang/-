<mxfile host="Electron" agent="Claude">
  <diagram name="避障数据流" id="avoid-dataflow-1">
    <mxGraphModel dx="1400" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1700" pageHeight="900" background="#ffffff" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" parent="1" style="text;html=1;align=left;verticalAlign=top;fontSize=18;fontStyle=1;" value="二维平面避障（A*）数据流：A* 定拓扑 → 翻译成可飞航线 → 校验兜底 → 注入现有链路" vertex="1">
          <mxGeometry height="30" width="1500" x="40" y="20" as="geometry" />
        </mxCell>

        <mxCell id="cfg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F9A825;strokeWidth=2;fontSize=13;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="配置输入 avoidance&#10;&#10;• obstacles[]：圆 / 轴对齐矩形&#10;• turn_radius_m  R（人工配置）&#10;• leg_length_margin_m  L&#10;• clearance_m（安全距离）&#10;• grid.resolution_m / margin_m" vertex="1">
          <mxGeometry height="150" width="250" x="40" y="90" as="geometry" />
        </mxCell>

        <mxCell id="s1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;fontSize=13;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="① A* 内核（纯函数）&#10;&#10;• 平面→栅格离散化&#10;• 障碍按 r_obs+clearance 膨胀&#10;• 8 邻域 + 对角/欧氏启发&#10;输出：起点→终点的格点折线" vertex="1">
          <mxGeometry height="150" width="250" x="330" y="90" as="geometry" />
        </mxCell>

        <mxCell id="s2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;fontSize=13;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="② 出口翻译（纯函数）&#10;&#10;• 视线可达去冗余 / 拉直&#10;• 拐点写 WayPointS.r = R&#10;• 复用 corner_arc 生成圆弧&#10;输出：候选 RouteS（带圆弧）" vertex="1">
          <mxGeometry height="150" width="250" x="620" y="90" as="geometry" />
        </mxCell>

        <mxCell id="s3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;fontSize=13;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="③ 可飞性校验（纯函数）&#10;&#10;• 腿长 ≥ d_in + d_out + L&#10;  d = R·tan(Δψ/2)&#10;• 圆弧仍在真实障碍之外&#10;• Δψ 近 180° 判不可飞&#10;输出：通过 → RouteS；否则失败" vertex="1">
          <mxGeometry height="150" width="250" x="910" y="90" as="geometry" />
        </mxCell>

        <mxCell id="s4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;fontSize=13;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="④ 注入控制器&#10;&#10;• 仿真开始前一次性&#10;• 用规划 RouteS 替换&#10;  长机航线&#10;• 不修改主循环 _tick" vertex="1">
          <mxGeometry height="150" width="240" x="1200" y="90" as="geometry" />
        </mxCell>

        <mxCell id="down" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#546E7A;strokeWidth=2;dashed=1;fontSize=13;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="下游链路（本期不改）&#10;&#10;LeaderRoute 选段 → 位置跟踪环 → 加速度指令 → 三自由度模型&#10;僚机编队跟随长机　|　俯视图叠加障碍 + 规划航线" vertex="1">
          <mxGeometry height="90" width="1110" x="330" y="300" as="geometry" />
        </mxCell>

        <mxCell id="fallback" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;fontSize=13;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="校验不过 → 报错 + 回退原始航线（不让仿真崩）" vertex="1">
          <mxGeometry height="60" width="250" x="910" y="450" as="geometry" />
        </mxCell>

        <mxCell id="e1" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#37474F;strokeWidth=2;endArrow=block;" edge="1" source="cfg" target="s1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#37474F;strokeWidth=2;endArrow=block;" edge="1" source="s1" target="s2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#37474F;strokeWidth=2;endArrow=block;" edge="1" source="s2" target="s3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e4" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#2E7D32;strokeWidth=2;endArrow=block;" edge="1" source="s3" target="s4"><mxGeometry relative="1" as="geometry" /><mxCell id="e4l" value="通过" /></mxCell>
        <mxCell id="e5" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#37474F;strokeWidth=2;endArrow=block;" edge="1" source="s4" target="down"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e6" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#C62828;strokeWidth=2;endArrow=block;dashed=1;" edge="1" source="s3" target="fallback"><mxGeometry relative="1" as="geometry" /></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
