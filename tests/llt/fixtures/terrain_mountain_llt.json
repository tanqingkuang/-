  "schema": "terrain_mountain_demo.v1",
  "字段说明": {
    "coordinate_system": "布局坐标 u/v 单位 km；u 映射 ENU east，v 映射 ENU north；渲染层再把 north 翻转为 Quick3D z。",
    "geo_reference": "经纬度参考原点，对应 local_origin_uv_km；演示航线由该原点按 src/data/geo.py 映射到经纬度。",
    "mountain_chains": "山脉链骨架。polyline_uv 定义山脉走向，peaks 沿 station 分布，saddle_height_factor 控制连续鞍部高度。",
    "risk_zone": "布局回退风险区标记。场景未提供避障障碍时，risk_zone=true 的峰进入 3D riskZones；存在避障障碍时由其 enabled 状态驱动。",
    "detail": "细节层噪声和网格参数。默认 768，低配使用 512，也可在运行时覆盖。"
  },
